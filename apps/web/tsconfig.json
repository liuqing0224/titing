{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "strictPropertyInitialization": false,
    "types": ["vite/client", "vitest/globals"]
  },
  "include": ["src", "../../plugins/ops-console/web/src/**/*.ts", "../../plugins/ops-console/web/src/**/*.tsx"]
}
