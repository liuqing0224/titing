{
  "name": "@titing/server",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json --incremental false",
    "diagnose:task": "node --require ts-node/register src/titing/diagnose-task.ts",
    "migration:legacy": "node --require ts-node/register src/migrate-legacy.ts",
    "migration:run": "node dist/apps/server/src/run-migrations.js",
    "smoke:sqlite": "node --require ts-node/register src/titing/sqlite-smoke.ts",
    "start": "node dist/apps/server/src/main.js",
    "start:dev": "node --require ts-node/register src/main.ts",
    "test": "jest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@titing/core": "0.1.0",
    "@titing/plugin-api": "0.1.0",
    "fastify": "^5.8.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
