TZ=Asia/Shanghai
BACKEND_PORT=3000
VITE_API_BASE_URL=http://localhost:3000/api
AGENT_POOL_SIZE=2
AGENT_HEARTBEAT_TIMEOUT_SECONDS=60
DOCKER_BIN=/usr/bin/docker
AGENT_IMAGE=autodev-agent-runner:local
MEEGLE_CLI_BIN=meegle
MEEGLE_SOURCE_MODE=latest_sprint
MEEGLE_PROJECT_KEY=
MEEGLE_PROJECT_SCOPE_NAME=
MEEGLE_SPRINT_TYPE_NAME=
MEEGLE_DEMAND_TYPE_NAME=
MEEGLE_SPRINT_LINK_FIELD=
MEEGLE_NODE_NAME=
MEEGLE_QUERY_MQL=
MEEGLE_DETAIL_FIELDS=repo,branch,instruction,priority,description,title
MEEGLE_LATEST_SPRINT_DETAIL_FIELDS=description
TITING_PLUGIN_MEEGLE_MODE=polling
TITING_PLUGIN_MEEGLE_TASKS_FILE=/absolute/path/to/.titing/meegle/tasks.json
TITING_PLUGIN_MEEGLE_RESULTS_FILE=/absolute/path/to/.titing/meegle/results.json
CODEX_CLI_BIN=codex
CODEX_WORKDIR=/tmp/autodev-agent/workspaces
CODEX_TIMEOUT_MS=1800000
CODEX_IGNORE_USER_CONFIG=false
# Cursor CLI (`agent` or `cursor`; see README). Only one execution-engine plugin is active (highest priority wins).
CURSOR_CLI_BIN=agent
# If unset, falls back to CODEX_WORKDIR
# CURSOR_WORKDIR=/tmp/autodev-agent/workspaces
CURSOR_TIMEOUT_MS=1800000
# CURSOR_API_KEY=           # non-interactive auth; CLI also supports `cursor agent login`
# CURSOR_MODEL=
# CURSOR_AGENT_MODE=        # plan | ask (omit for default agent mode)
# CURSOR_OUTPUT_FORMAT=text
# CURSOR_SANDBOX=disabled
# CURSOR_TRUST_WORKSPACE=true
# CURSOR_FORCE_COMMANDS=true
# CURSOR_APPROVE_MCPS=false
HOST_CODEX_HOME=/absolute/path/to/.codex
HOST_GITCONFIG=/absolute/path/to/.gitconfig
HOST_SSH_DIR=/absolute/path/to/.ssh
HOST_PROJECTS_ROOT=/absolute/path/to/projects/root
# Nest 应用日志（MeegleAdapter、Runner 等）同时写入文件；默认 logs/server.log
# NEST_LOG_TO_FILE=false
# NEST_LOG_DIR=logs
# NEST_LOG_FILE=server.log
