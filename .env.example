# =========================
# 基础运行配置
# =========================

# 服务端口。前端默认通过 VITE_API_BASE_URL 访问这个地址。
BACKEND_PORT=3000

# 前端访问后端 API 的地址。
VITE_API_BASE_URL=http://localhost:3000/api

# SQLite 数据库文件路径。默认值为 .titing/sqlite/titing.sqlite。
DATABASE_FILE=.titing/sqlite/titing.sqlite


# =========================
# Scheduler / Agent
# =========================

# scheduler tick 间隔，单位毫秒。生产上不建议配得太小。
TITING_SCHEDULER_INTERVAL_MS=30000

# 启动时预创建的 agent 数量。
TITING_SCHEDULER_AGENT_COUNT=2

# agent 心跳超时阈值，单位毫秒。超过后 busy agent 会被判定为 offline。
TITING_SCHEDULER_AGENT_OFFLINE_TIMEOUT_MS=300000


# =========================
# Workspace
# =========================

# task worktree 根目录。
TITING_WORKSPACE_ROOT=.titing/workspaces

# repo bare mirror 缓存目录。
TITING_WORKSPACE_REPO_CACHE_ROOT=.titing/repos

# 执行成功后是否删除 workspace。
TITING_WORKSPACE_CLEANUP_ON_SUCCESS=false

# 执行失败后是否删除 workspace。排障时通常建议保留。
TITING_WORKSPACE_CLEANUP_ON_FAILURE=false


# =========================
# Goal Recovery / Repair Loop
# =========================

# 执行器命令超时，单位毫秒。
TITING_GOAL_EXECUTION_TIMEOUT_MS=1800000

# 质量检查阶段超时，单位毫秒。
TITING_GOAL_QUALITY_TIMEOUT_MS=600000

# 环境准备失败的自动重试次数。
TITING_GOAL_ENVIRONMENT_RETRY_LIMIT=2

# 执行阶段 timeout / launch_error 的自动重试次数。
TITING_GOAL_EXECUTION_RETRY_LIMIT=2

# Goal Loop 最大 repair 轮次。
TITING_GOAL_MAX_REPAIR_ITERATIONS=3

# 是否启用自动 needs_human 闭环。
# false：stop signal 继续 repair，直到 budget exhausted 或成功。
# true：high_risk / repeated_failure / no_effective_diff 可自动转 needs_human，
#      并在插件支持时通过评论回写、读取用户回复后自动恢复。
TITING_GOAL_ENABLE_NEEDS_HUMAN_LOOP=false


# =========================
# 外部插件替换
# =========================

# 按插件类型指定外部插件包名或模块路径。留空时使用内置插件。
# 外部插件包需导出 createPlugin({ serverConfig, pluginKind })。

# 替换任务集成插件，例如 GitHub Issue / Jira / 自定义来源。
# TITING_PLUGIN_TASK_INTEGRATION_PACKAGE=@your-scope/titing-task-integration-plugin

# 替换执行器插件。配置后可把默认 executor 改成该插件支持的 capability。
# TITING_PLUGIN_EXECUTION_PACKAGE=@your-scope/titing-execution-plugin

# 替换环境准备插件。
# TITING_PLUGIN_ENVIRONMENT_PACKAGE=@your-scope/titing-environment-plugin

# 替换质量检查插件。
# TITING_PLUGIN_QUALITY_PACKAGE=@your-scope/titing-quality-plugin

# 替换治理插件。
# TITING_PLUGIN_OBSERVABILITY_GOVERNANCE_PACKAGE=@your-scope/titing-governance-plugin

# 替换日志插件。
# TITING_PLUGIN_LOG_PACKAGE=@your-scope/titing-log-plugin


# =========================
# 执行器配置
# =========================

# 未显式指定 executor 的任务默认执行器。
# 内置执行器可选 codex / cursor。
# 若使用外部 execution 插件，这里填写该插件支持的 capability 名称。
TITING_DEFAULT_EXECUTOR=codex

# Codex CLI 可执行文件名或绝对路径。
TITING_PLUGIN_EXECUTION_CODEX_BIN=codex

# Cursor CLI 可执行文件名或绝对路径。
TITING_PLUGIN_EXECUTION_CURSOR_BIN=agent


# =========================
# Meegle 集成
# =========================

# 集成模式：
# polling  通过文件或 CLI 主动拉取任务
# webhook  通过 HTTP webhook 接收任务
TITING_PLUGIN_MEEGLE_MODE=polling

# Meegle CLI 可执行文件名或绝对路径。
MEEGLE_CLI_BIN=meegle

# 任务来源模式：
# latest_sprint 表示按“最新迭代 -> 需求”链路拉取
# 留空则走 queryMql 或默认 CLI 流程
MEEGLE_SOURCE_MODE=latest_sprint

# Meegle 设备码登录时可指定 host。
# MEEGLE_AUTH_HOST=

# Meegle CLI profile 名称。多账号隔离时有用。
# MEEGLE_AUTH_PROFILE=

# 项目标识。CLI 拉取 / 评论写回常用。
MEEGLE_PROJECT_KEY=

# latest_sprint 模式所需配置。
MEEGLE_PROJECT_SCOPE_NAME=
MEEGLE_SPRINT_TYPE_NAME=
MEEGLE_DEMAND_TYPE_NAME=
MEEGLE_SPRINT_LINK_FIELD=

# latest_sprint 模式下可选的节点名过滤，例如“开发中”。
MEEGLE_NODE_NAME=

# 自定义 MQL 查询。latest_sprint 模式下通常可留空。
MEEGLE_QUERY_MQL=

# workitem detail 拉取字段列表，逗号分隔。
MEEGLE_DETAIL_FIELDS=repo,branch,instruction,priority,description,title

# latest_sprint 明细字段列表，逗号分隔。
MEEGLE_LATEST_SPRINT_DETAIL_FIELDS=description

# 文件型 polling 任务源。配置后会直接读取本地 JSON 文件。
# TITING_PLUGIN_MEEGLE_TASKS_FILE=/absolute/path/to/.titing/meegle/tasks.json

# 文件型结果回写。仅当同时配置 tasks file 时有效。
# TITING_PLUGIN_MEEGLE_RESULTS_FILE=/absolute/path/to/.titing/meegle/results.json

# webhook 模式下的共享密钥。
# TITING_PLUGIN_MEEGLE_WEBHOOK_SECRET=


# =========================
# Governance
# =========================

# 命令 allowlist，逗号分隔。留空表示不启用 allowlist。
TITING_GOVERNANCE_ALLOW_COMMAND_PREFIXES=

# 危险命令正则 blocklist，逗号分隔。
TITING_GOVERNANCE_BLOCK_COMMAND_PATTERNS=\\bgit\\s+push\\b,\\brm\\s+-rf\\s+/,\\bterraform\\s+destroy\\b,\\baws\\s+iam\\b,\\bssh\\b,\\bscp\\b

# 单次命令 prompt 最大字符数。
TITING_GOVERNANCE_MAX_PROMPT_CHARS=16000

# stdout/stderr 最大保留字符数。
TITING_GOVERNANCE_MAX_OUTPUT_CHARS=12000

# diff 中文件数阈值，超过后治理会升级风险。
TITING_GOVERNANCE_MAX_FILES_CHANGED=20

# diff 行数阈值，超过后治理会升级风险。
TITING_GOVERNANCE_MAX_DIFF_LINES=400
